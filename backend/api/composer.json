{
  "name": "cours-alexandre-ouellet/exposat",
  "description": "Back-end du projet de refonte du site web d'ExpoSAT.",
  "type": "project",
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src",
      "Test\\": "tests"
    },
    "classmap": [
      "src/",
      "tests/"
    ]
  },
  "authors": [
    {
      "name": "Christopher Boisvert"
    },
    {
      "name": "Jean-Philippe Bourrassa"
    },
    {
      "name": "Tomy Chouinard"
    },
    {
      "name": "Souleymane Soumare"
    },
    {
      "name": "Mathieu Sévégny"
    },
    {
      "name": "Tristan Lafontaine"
    },
    {
      "name": "Charles Lavoie"
    },
    {
      "name": "Alex Des Ruisseaux"
    },
    {
      "name": "Tommy Garneau"
    },
    {
      "name": "Carlos Cordeiro"
    },
    {
      "name": "Alexis Boivin"
    },
    {
      "name": "Étienne Nadeau"
    },
    {
      "name": "Antoine Ouellette"
    }
  ],
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "symfony/dotenv": "^5.4",
    "phpstan/phpstan": "^2.1",
    "slevomat/coding-standard": "^8.28"
  },
  "require": {
    "php": "^8.2",
    "slim/slim": "4.*",
    "slim/psr7": "^1.5",
    "php-di/slim-bridge": "^3.1",
    "ext-pdo": "*",
    "ext-json": "*",
    "lcobucci/jwt": "^3.4",
    "phpmailer/phpmailer": "^6.7",
    "twig/twig": "^3.3"
  }
}
